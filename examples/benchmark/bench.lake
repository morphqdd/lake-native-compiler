@rt(rt_write)

worker is {
  n str -> {
    rt_write(1 n 7)
  }
}

main is {
  n i64.0 -> {
    worker("task 0\n")
    worker("task 1\n")
    worker("task 2\n")
    worker("task 3\n")
    worker("task 4\n")
    worker("task 5\n")
    worker("task 6\n")
    worker("task 7\n")
    worker("task 8\n")
    worker("task 9\n")
  }
}
